{
  "name": "karate-cockpit-v1",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "python3 -m http.server 4173",
    "check": "node --check app.js && python3 -m json.tool manifest.webmanifest >/dev/null && npm run smoke && npm run test:e2e",
    "smoke": "node qa-smoke.mjs",
    "test:e2e": "playwright test",
    "test:e2e:webkit": "playwright test --project=\"Mobile Safari-ish WebKit\""
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
